-- CrГ©ation de la base de donnГ©es
CREATE DATABASE IF NOT EXISTS ferrari_vitrine;
USE ferrari_vitrine;

-- Table USERS
CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nom VARCHAR(100) NOT NULL,
    prenom VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,  -- password_hash() gГ©nГЁre des strings de 255 chars
    avatar_url VARCHAR(500) DEFAULT NULL,
    role ENUM('user', 'admin') DEFAULT 'user',
    created_at DATETIME DEFAULT NOW()
);

-- Table VOITURE (corrigГ©e : annee, vitesse_max, moteur)
CREATE TABLE voiture (
    id INT AUTO_INCREMENT PRIMARY KEY,
    modele VARCHAR(100) NOT NULL,
    annee INT NOT NULL,
    puissance_ch INT NOT NULL,
    vitesse_max INT NOT NULL,
    moteur VARCHAR(100) NOT NULL,
    prix DECIMAL(10,2) NOT NULL,
    description TEXT DEFAULT NULL,
    glb_url VARCHAR(500) NOT NULL,       -- Chemin vers ton .glb (ex: /assets/models/ferrari296.glb)
    sound_url VARCHAR(500) DEFAULT NULL, -- Chemin vers ton son (ex: /assets/sounds/ferrariEngine.wav)
    image_url VARCHAR(500) DEFAULT NULL, -- Fallback mobile
    created_at DATETIME DEFAULT NOW()
);

-- Table AVIS (ajoutГ©e, manquante dans ton CDC)
CREATE TABLE avis (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    voiture_id INT NOT NULL,
    note TINYINT NOT NULL CHECK (note BETWEEN 1 AND 5),
    commentaire TEXT,
    is_flagged TINYINT(1) DEFAULT 0,
    is_deleted TINYINT(1) DEFAULT 0,
    created_at DATETIME DEFAULT NOW(),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (voiture_id) REFERENCES voiture(id) ON DELETE CASCADE
);

-- Table MESSAGES (corrigГ©e : coontent -> content)
CREATE TABLE messages (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    content TEXT NOT NULL,
    is_flagged TINYINT(1) DEFAULT 0,
    is_deleted TINYINT(1) DEFAULT 0,
    created_at DATETIME DEFAULT NOW(),
    updated_at DATETIME ON UPDATE NOW(),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Table CONTACT_REQUESTS
CREATE TABLE contact_requests (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nom VARCHAR(100) NOT NULL,
    email VARCHAR(100) NOT NULL,
    sujet VARCHAR(255) NOT NULL,
    message TEXT NOT NULL,
    is_read TINYINT(1) DEFAULT 0,
    created_at DATETIME DEFAULT NOW()
);

-- Index pour optimisation
CREATE UNIQUE INDEX idx_users_email ON users(email);
CREATE INDEX idx_users_role ON users(role);
CREATE INDEX idx_avis_user ON avis(user_id);
CREATE INDEX idx_avis_voiture ON avis(voiture_id);
CREATE INDEX idx_avis_deleted ON avis(is_deleted);
CREATE INDEX idx_avis_flagged ON avis(is_flagged);
CREATE INDEX idx_cr_read ON contact_requests(is_read);
CREATE INDEX idx_cr_date ON contact_requests(created_at);

